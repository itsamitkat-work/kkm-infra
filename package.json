{
  "name": "kkm-infra",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:types": "supabase gen types typescript --local > packages/db/src/database.types.ts",
    "seed:app": "bash supabase/scripts/seed-app.sh",
    "seed:schedule": "bash supabase/scripts/seed-app.sh",
    "db:reset:seed": "supabase db reset && bash supabase/scripts/seed-app.sh",
    "deploy": "pnpm --filter web deploy"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.7.1",
    "turbo": "^2.5.4"
  }
}
