# Copy to `.env` at repo root for local tooling (optional).
# Next.js also reads `apps/web/.env.local` — use either pattern.
#
# Local (after `supabase start` — values from `supabase status`):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Hosted staging / production — Dashboard → Project Settings → API:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never NEXT_PUBLIC_*): service role key, webhooks, etc.
# SUPABASE_SERVICE_ROLE_KEY=
