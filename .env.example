# Copy to `.env` at repo root for local tooling (optional).
# Next.js also reads `apps/web/.env.local` — use either pattern.
#
# Local (after `supabase start` — values from `supabase status`):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Hosted preview(develop) / production — Dashboard → Project Settings → API Keys:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Server-only (never NEXT_PUBLIC_*):
# SUPABASE_SECRET_KEY=
